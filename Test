local LocalPlayer = Players.LocalPlayer
local Events = ReplicatedStorage:WaitForChild("Events")

-- Wait for character and required instances
local function waitForCharacter()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    character:WaitForChild("HumanoidRootPart")
    return character
end

-- Claim all crates: collect cubes + claim timed rewards
local function claimCrates()
    local character = waitForCharacter()
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- 1. Collect cubes (as in original "Auto collect")
    local cubeVis = LocalPlayer.PlayerScripts:FindFirstChild("CubeVis")
    if cubeVis then cubeVis.Enabled = false end

    for _, obj in pairs(Workspace:GetChildren()) do
        if obj.Name == "Cube" and obj:FindFirstChild("Owner") then
            local owner = obj.Owner.Value
            if owner == LocalPlayer.Name or owner == "" then
                pcall(function()
                    obj.CFrame = root.CFrame
                end)
            end
        end
    end

    if cubeVis then cubeVis.Enabled = true end

    -- 2. Claim timed rewards (as in original "Auto claim")
    for _, reward in pairs(LocalPlayer.TimedRewards:GetChildren()) do
        if reward.Value > 0 then
            pcall(function()
                Events.RewardEvent:FireServer(reward)
            end)
        end
    end

    -- Also fire spin event (optional, from original)
    pcall(function()
        Events.SpinEvent:FireServer()
    end)

    -- Simple feedback (optional)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Claim Crates",
        Text = "Cubes collected & rewards claimed!",
        Duration = 3
    })
end

-- Reset all crate timers by setting their value to 0
local function resetCrates()
    for _, reward in pairs(LocalPlayer.TimedRewards:GetChildren()) do
        pcall(function()
            reward.Value = 0
        end)
    end
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Reset Crates",
        Text = "All crate timers have been reset!",
        Duration = 3
    })
end

