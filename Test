-- ===================== Functions =====================

local function ClaimCrates()
    if not LocalPlayer:FindFirstChild("TimedRewards") then return end
    
    for _, reward in pairs(LocalPlayer.TimedRewards:GetChildren()) do
        if reward.Value and reward.Value > 0 then
            Events.RewardEvent:FireServer(reward)
        end
    end
    Events.SpinEvent:FireServer()
end

local function ResetCrates()
    if not LocalPlayer:FindFirstChild("TimedRewards") then return end
    
    for _, reward in pairs(LocalPlayer.TimedRewards:GetChildren()) do
        if reward.Value then
            -- Reset timer to 0 (forces countdown to restart)
            reward.Value = 0
        end
    end
end

-- ===================== Button Connections =====================

ClaimBtn.MouseButton1Click:Connect(function()
    ClaimCrates()
    ClaimBtn.Text = "Crates Claimed!"
    task.wait(1.5)
    ClaimBtn.Text = "Claim Crates"
end)

ResetBtn.MouseButton1Click:Connect(function()
    ResetCrates()
    ResetBtn.Text = "Crates Reset!"
    task.wait(1.5)
    ResetBtn.Text = "Reset Crates"
end)

-- Optional: Auto claim every 30 seconds
task.spawn(function()
    while task.wait(30) do
        ClaimCrates()
    end
end)

print("✅ Crates Manager Loaded!")
