-- ===================== Functions =====================

local function ClaimCrates()
    if not LocalPlayer:FindFirstChild("TimedRewards") then return end
    
    for _, reward in pairs(LocalPlayer.TimedRewards:GetChildren()) do
        if reward.Value and reward.Value > 0 then
            Events.RewardEvent:FireServer(reward)
        end
    end
    Events.SpinEvent:FireServer()
end

local function ResetCrates()
    if not LocalPlayer:FindFirstChild("TimedRewards") then return end
    
    local rewards = LocalPlayer.TimedRewards:GetChildren()
    table.sort(rewards, function(a,b) return a.Name < b.Name end) -- sort for consistency
    
    for i, reward in ipairs(rewards) do
        if reward:IsA("IntValue") or reward:IsA("NumberValue") then
            if i <= 3 then
                reward.Value = 5 * 60   -- 5 minutes
            elseif i <= 6 then
                reward.Value = 10 * 60  -- 10 minutes
            else
                reward.Value = 15 * 60  -- 15 minutes
            end
        end
    end
end

-- ===================== Buttons =====================

ClaimBtn.MouseButton1Click:Connect(function()
    ClaimBtn.Text = "Claiming..."
    ClaimCrates()
    task.wait(1)
    ClaimBtn.Text = "Claim All Crates"
end)

ResetBtn.MouseButton1Click:Connect(function()
    ResetBtn.Text = "Resetting Timers..."
    ResetCrates()
    task.wait(1.2)
    ResetBtn.Text = "Reset Timers (Restart Countdown)"
end)

print("✅ Crates Manager Loaded - Timers now restart properly!")
