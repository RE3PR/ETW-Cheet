ResetBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
ResetBtn.Text = "Reset Crates (Restart Timer)"
ResetBtn.TextColor3 = Color3.new(1,1,1)
ResetBtn.TextSize = 18
