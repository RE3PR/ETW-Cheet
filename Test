-- ===================== Functions =====================

local function ClaimCrates()
    if not LocalPlayer:FindFirstChild("TimedRewards") then 
        warn("TimedRewards folder not found")
        return 
    end
    
    for _, reward in pairs(LocalPlayer.TimedRewards:GetChildren()) do
        if reward:IsA("IntValue") or reward:IsA("NumberValue") then
            if reward.Value > 0 then
                Events.RewardEvent:FireServer(reward)
            end
        end
    end
    Events.SpinEvent:FireServer()
end

local function ResetCrates()
    if not LocalPlayer:FindFirstChild("TimedRewards") then 
        warn("TimedRewards folder not found")
        return 
    end
    
    -- This forces the timers to restart their full countdown
    for _, reward in pairs(LocalPlayer.TimedRewards:GetChildren()) do
        if reward:IsA("IntValue") or reward:IsA("NumberValue") then
            -- Setting to a high number restarts the countdown from maximum time
            reward.Value = 999999  
        end
    end
end

-- ===================== Connections =====================

ClaimBtn.MouseButton1Click:Connect(function()
    ClaimBtn.Text = "Claiming..."
    ClaimCrates()
    task.wait(1)
    ClaimBtn.Text = "Claim Crates"
end)

ResetBtn.MouseButton1Click:Connect(function()
    ResetBtn.Text = "Resetting Timers..."
    ResetCrates()
    task.wait(1.2)
    ResetBtn.Text = "Reset Crates (Restart Timer)"
end)

print("✅ Crates Manager Loaded - Reset now properly restarts countdown!")
