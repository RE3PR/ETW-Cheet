-- 检查白名单
local function checkWhitelist()
    local localPlayer = Players.LocalPlayer
    if not localPlayer then return false end
    local isWhitelistedUser = isWhitelisted(localPlayer)
    if not isWhitelistedUser then
        print("[Whitelist System] Detected non-whitelisted user:", localPlayer.Name)
        showWhitelistWarning()
        return true
    end
    return false
end
