-- 检查玩家是否在白名单中
local function isWhitelisted(player)
    if not player then return false end
    local playerName = player.Name
    for _, whitelisted in ipairs(whitelist) do
        if whitelisted == playerName then
            return true
        end
    end
    return false
end
